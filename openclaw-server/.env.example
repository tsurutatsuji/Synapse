# ─── 必須 ───
# 管理API の認証キー（Vercel 側の OPENCLAW_ADMIN_KEY と同じ値にする）
OPENCLAW_ADMIN_KEY=""
PORT=3100
# OpenClaw ゲートウェイの内部トークン
GATEWAY_TOKEN=""

# ─── CORS（本番必須） ───
# Vercel ダッシュボードの URL（カンマ区切りで複数指定可）
ALLOWED_ORIGINS="https://your-app.vercel.app"

# ─── Gemini 無料枠（任意） ───
# ユーザーが API キー未指定の場合に使用
# https://aistudio.google.com/apikey で取得
GOOGLE_AI_KEY=""
