# ─── データベース（PostgreSQL） ───
# Neon 無料プラン推奨: https://neon.tech
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# ─── NextAuth ───
NEXTAUTH_SECRET="ランダムな文字列を生成して設定してください"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth（任意 — Google ログインを使う場合のみ）───
# https://console.cloud.google.com/ で作成
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── OpenClaw マルチテナント（本番必須）───
# OpenClaw サーバーのベースURL（末尾スラッシュなし）
OPENCLAW_HOST="https://your-openclaw.up.railway.app"
# OpenClaw 管理API の認証キー
OPENCLAW_ADMIN_KEY="your-admin-secret-key"
