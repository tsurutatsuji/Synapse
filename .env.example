# ─── データベース（PostgreSQL） ───
# Neon 無料プラン推奨: https://neon.tech
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# ─── NextAuth ───
# 重要: 必ず安全なランダム値を設定してください
# 生成方法: openssl rand -hex 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth（必須） ───
# https://console.cloud.google.com/ で作成
# 認証 > OAuth 2.0 クライアント ID から取得
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── 暗号化キー（必須） ───
# DB に保存する API キー・LINE トークンの暗号化に使用
# 生成方法: openssl rand -hex 32
# 一度設定したら絶対に変更しないでください（既存データが復号できなくなります）
ENCRYPTION_KEY=""

# ─── OpenClaw マルチテナント（本番必須） ───
# OpenClaw サーバーのベースURL（末尾スラッシュなし）
# 本番環境では必ず HTTPS を使用してください
OPENCLAW_HOST="https://your-openclaw.up.railway.app"
# OpenClaw 管理API の認証キー（openssl rand -hex 32 で生成）
OPENCLAW_ADMIN_KEY=""
