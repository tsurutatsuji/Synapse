{
  "id": "example-001",
  "name": "ファイル読込→変換→書込",
  "description": "ファイルを読み込み、データを変換して別のファイルに書き出すサンプルワークフロー",
  "nodes": [
    {
      "id": "node-1",
      "nodeDefinitionId": "file-reader",
      "x": 100,
      "y": 200,
      "config": {
        "filePath": "./data/input.txt",
        "encoding": "utf-8"
      }
    },
    {
      "id": "node-2",
      "nodeDefinitionId": "transform-node",
      "x": 400,
      "y": 200,
      "config": {
        "expression": "data.toUpperCase()"
      }
    },
    {
      "id": "node-3",
      "nodeDefinitionId": "file-writer",
      "x": 700,
      "y": 200,
      "config": {
        "filePath": "./data/output.txt",
        "append": "false"
      }
    }
  ],
  "edges": [
    {
      "id": "edge-1",
      "sourceNodeId": "node-1",
      "sourcePortId": "content",
      "targetNodeId": "node-2",
      "targetPortId": "data"
    },
    {
      "id": "edge-2",
      "sourceNodeId": "node-2",
      "sourcePortId": "result",
      "targetNodeId": "node-3",
      "targetPortId": "content"
    }
  ],
  "createdAt": "2026-02-27T00:00:00.000Z",
  "updatedAt": "2026-02-27T00:00:00.000Z"
}
